{
    "$schema": "https://biomejs.dev/schemas/1.5.1/schema.json",
    "organizeImports": {
        "enabled": true
    },
    "files": {
        "maxSize": 1500000
    },
    "linter": {
        "enabled": true,
        "rules": {
            "security": {
                "noDangerouslySetInnerHtml": "off",
                "noDangerouslySetInnerHtmlWithChildren": "off"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "formatWithErrors": false,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 80,
        "ignore": [
            "**/*/generated-new.ts",
            "**/*/generated-v2.ts"
        ]
    },
    "javascript": {
        "formatter": {
            "jsxQuoteStyle": "single",
            "semicolons": "always",
            "quoteStyle": "single",
            "trailingCommas": "all"
        }
    }
}