{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "index.tsx",
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    "react-native-css-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/components/ui/chat-ai",
    "src/components/ui/bottomsheet",
    "src/components/ui/liquid-glass",
    "src/components/ui/image-viewer",
    "src/components/ui/date-time-picker",
    "src/components/ui/accordion/USAGE_EXAMPLE.tsx"
  ]
}
