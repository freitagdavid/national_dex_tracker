{
    "name": "opendex",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "packageManager": "yarn@4.5.0",
    "private": true,
    "scripts": {
        "upgrade:tamagui": "yarn up '*tamagui*'@latest '@tamagui/*'@latest",
        "upgrade:tamagui:canary": "yarn up '*tamagui*'@canary '@tamagui/*'@canary",
        "check:tamagui": "tamagui check",
        "start": "expo start -c",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "test": "jest --watchAll",
        "lint": "npx biome lint",
        "lint:fix": "npx biome lint --write",
        "format": "npx biome format",
        "format:fix": "npx biome format --write",
        "check": "npx biome check",
        "check:fix": "npx biome check --write"
    },
    "jest": {
        "preset": "jest-expo"
    },
    "dependencies": {
        "@biomejs/biome": "^1.9.4",
        "@react-navigation/native": "^6.1.17",
        "@reduxjs/toolkit": "^2.3.0",
        "@tamagui/config": "^1.116.14",
        "@tamagui/lucide-icons": "^1.116.14",
        "@tamagui/toast": "^1.116.14",
        "babel-preset-expo": "^11.0.6",
        "burnt": "^0.12.2",
        "expo": "~51.0.32",
        "expo-build-properties": "~0.12.5",
        "expo-font": "~12.0.10",
        "expo-linking": "~6.3.1",
        "expo-router": "~3.5.23",
        "expo-splash-screen": "~0.27.5",
        "expo-status-bar": "^1.12.1",
        "expo-system-ui": "~3.0.7",
        "expo-web-browser": "~13.0.3",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-native": "0.75.2",
        "react-native-reanimated": "~3.15.1",
        "react-native-safe-area-context": "4.10.9",
        "react-native-screens": "~3.34.0",
        "react-native-svg": "15.6.0",
        "react-native-web": "^0.19.12",
        "react-redux": "^9.1.2",
        "tamagui": "^1.116.14"
    },
    "devDependencies": {
        "@babel/core": "^7.24.6",
        "@expo/metro-config": "~0.18.4",
        "@expo/metro-runtime": "~3.2.1",
        "@tamagui/babel-plugin": "^1.116.14",
        "@tamagui/cli": "^1.116.14",
        "@tamagui/metro-plugin": "^1.116.14",
        "@types/react": "~18.2.79",
        "@types/react-native": "^0.73.0",
        "typescript": "^5.5.2"
    },
    "trustedDependencies": ["core-js"]
